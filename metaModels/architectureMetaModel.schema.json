{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.deltamodel.architecture.assistant/schema/architectureMetaModel.schema.json",
  "title": "Architecture MetaModel",
  "type": "object",
  "required": [
    "format",
    "schemaVersion",
    "name",
    "version",
    "architecture"
  ],
  "properties": {
    "format": {
      "type": "string",
      "const": "architectureMetaModel"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 2
    },
    "metaModelId": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    },
    "documentation": {
      "type": "object"
    },
    "architecture": {
      "type": "object",
      "required": [
        "views",
        "nodeTypes",
        "edgeTypes"
      ],
      "properties": {
        "views": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "category": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "nodeTypes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string"
              },
              "stereotype": {
                "type": "string"
              },
              "isAbstract": {
                "type": "boolean"
              },
              "allowedViews": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "generalizes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "baseStereotypes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "attributes": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "edgeTypes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string"
              },
              "stereotype": {
                "type": "string"
              },
              "direction": {
                "type": "string",
                "enum": [
                  "directed",
                  "undirected"
                ]
              },
              "umlTypes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "sourceNodeTypes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "targetNodeTypes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "allowedViews": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "strokeStyle": {
                "type": "string",
                "enum": [
                  "solid",
                  "dashed",
                  "dotted"
                ]
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
